{
  "name": "@chowvest/database",
  "version": "0.1.0",
  "main": "./index.ts",
  "types": "./index.ts",
  "scripts": {
    "generate": "prisma generate --config=../../prisma.config.ts",
    "db:push": "prisma db push --config=../../prisma.config.ts",
    "db:migrate": "prisma migrate dev --config=../../prisma.config.ts",
    "db:reset": "prisma migrate reset --config=../../prisma.config.ts",
    "db:seed": "prisma db seed --config=../../prisma.config.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "prisma": "^7.8.0"
  }
}